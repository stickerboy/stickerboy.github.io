---
layout: base.njk
cssFile: home
tags:
  - photographs
pagination:
  data: photos
  size: 1
  alias: photo
  resolve: values
permalink: /photography/{{ photo.slug }}/
---

<section class="showcase photo">
    <div class="container-fluid p-0">
        <div class="row g-0">
            <div class="col-lg-6 my-auto showcase-text p-5 p-md-9">
                <h2>About this photo</h2>

                {% if photo.summary %}
                    <p class="fs-6 mt-3">{{ photo.summary }}</p>
                {% endif %}
                {% if photo.description %}
                    <p class="fs-6 mt-3">{{ photo.description }}</p>
                {% endif %}
                {% if photo.details %}
                    <p class="visually-hidden fs-6 mt-{% if photo.summary %}1{% else %}3{% endif %}">{{ photo.details }}</p>
                {% endif %}


                {% if photo.photoUrl %}
                <p><a href="{{ photo.photoUrl }}" class="btn btn-light" rel="noopener" target="_blank">View this image on Flickr</a></p>
                {% endif %}
            </div>
            <div class="col-lg-6 text-white showcase-img"
                style="background-image: url('{{ photo.photoId | assetImagePath(photo.imageExtension or 'jpg', '', tags)  }}')"
                aria-describedby="showcase-detail-img"></div>
            <p class="visually-hidden" id="showcase-detail-img">{{ photo.imageAlt or photo.title }}</p>
        </div>
    </div>
</section>
{% if photo.tags %}
    <section class="py-md-5 py-4">
        <div class="container pm-0">
            {% for tag in photo.tags %}
            <small class="d-inline-flex {% if not loop.last %}me-2 {% endif %}my-2 px-2 py-1 fw-semibold text-success-emphasis bg-light-subtle border border-stckr-subtle rounded-2">
                {{ tag }}
            </small>
            {% endfor %}
        </div>
    </section>
{% endif %}
{% if photo.exif %}
<section class="py-md-6 py-5 bg-light">
    <div class="container">
        <h2>Exif</h2>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 mt-4">
            {% if photo.exif.camera or photo.exif.model %}
            <div class="col mb-4">
                <h3 class="h5">Camera</h3>
                <p class="mb-0">{{ photo.exif.camera | replace("OLYMPUS IMAGING CORP.", "Olympus Pen ") or "Unknown" }}{% if photo.exif.model %} {{ photo.exif.model | replace("OLYMPUS IMAGING CORP.", "Olympus Pen ") }}{% endif %}</p>
            </div>
            {% endif %}

            {% if photo.exif.lens %}
            <div class="col mb-4">
                <h3 class="h5">Lens</h3>
                <p class="mb-0">{{ photo.exif.lens | replace("OLYMPUS", "Olympus") }}</p>
            </div>
            {% endif %}

            {% if photo.exif.iso %}
            <div class="col mb-4">
                <h3 class="h5">ISO</h3>
                <p class="mb-0">{{ photo.exif.iso }}</p>
            </div>
            {% endif %}

            {% if photo.exif.dateTimeOriginal %}
            <div class="col mb-4">
                <h3 class="h5">Date Taken</h3>
                <p class="mb-0">{{ photo.exif.dateTimeFormatted or photo.exif.dateTimeOriginal }}</p>
            </div>
            {% endif %}

            {% if photo.exif.shutterSpeed %}
            <div class="col mb-4">
                <h3 class="h5">Shutter Speed</h3>
                <p class="mb-0">{{ photo.exif.shutterSpeed }} sec</p>
            </div>
            {% endif %}

            {% if photo.exif.focalLength %}
            <div class="col mb-4">
                <h3 class="h5">Focal Length</h3>
                <p class="mb-0">{{ photo.exif.focalLength }}mm</p>
            </div>
            {% endif %}

            {% if photo.exif.aperture %}
            <div class="col mb-4">
                <h3 class="h5">Aperture</h3>
                <p class="mb-0">ƒ/{{ photo.exif.aperture }}</p>
            </div>
            {% endif %}

            {% if photo.exif.location %}
            <div class="col mb-4">
                <h3 class="h5">Location</h3>
                <p class="mb-0">
                    <a href="https://maps.google.com/?q={{ photo.exif.location.latitude }},{{ photo.exif.location.longitude }}" 
                       class="link-stckr" rel="noopener" target="_blank">
                       {{ photo.exif.location.latitude }}, {{ photo.exif.location.longitude }}
                    </a>
                </p>
            </div>
            {% endif %}

            {% if photo.exif.software %}
            <div class="col mb-4">
                <h3 class="h5">Software</h3>
                <p class="mb-0">{{ photo.exif.software }}</p>
            </div>
            {% endif %}
        </div>
    </div>
</section>
{% endif %}

<section class="py-md-4 py-3">
        <div class="container">

        {% include "components/pagination.njk" %}
        <p class="mb-0"><a href="/photography/" class="btn btn-outline-stckr">Back to all photography</a></p>
    </div>
</section>
