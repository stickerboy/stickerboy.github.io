{
  "name": "kennycx",
  "version": "2.0.0",
  "description": "I'm a web-designing code-decrypting tech-support musician",
  "main": "index.html",
  "scripts": {
    "dev": "sass --watch --update --style=expanded scss:assets/devcss",
    "prod": "sass --no-source-map --style=compressed scss:_site/assets/css",
    "build": "npx @11ty/eleventy --formats=html",
    "serve": "npx eleventy --serve",
    "deploy": "git subtree push --prefix _site origin gh-pages"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stickerboy/stickerboy.github.io.git"
  },
  "bugs": {
    "url": "https://github.com/stickerboy/stickerboy.github.io/issues"
  },
  "author": "Kenny Cameron",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@tailwindcss/postcss": "^4.2.2",
    "cssnano": "^7.1.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2"
  }
}
