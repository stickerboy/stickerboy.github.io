{
  "name": "kennycx",
  "version": "2.0.0",
  "description": "I'm a web-designing code-decrypting tech-support musician",
  "main": "index.html",
  "scripts": {
    "build:devcss": "sass --watch --update --style=expanded scss:assets/devcss",
    "build:css": "sass --no-source-map --style=compressed scss:assets/css",
    "prebuild": "npm run build:css",
    "build": "npx @11ty/eleventy --formats=njk,md,html",
    "serve": "npx eleventy --serve",
    "deploy": "git subtree push --prefix _site origin gh-pages"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stickerboy/stickerboy.github.io.git"
  },
  "bugs": {
    "url": "https://github.com/stickerboy/stickerboy.github.io/issues"
  },
  "author": "Kenny Cameron",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "bootstrap-scss": "^5.3.8"
  }
}
