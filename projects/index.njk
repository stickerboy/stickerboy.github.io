---
layout: base.njk
title: Projects
pageHeading: Projects
description: This page is a collection of projects I have been building and improving over time, from practical tools to creative experiments that reflect what I enjoy making and learning.
cssFile: home
---

<section class="projects card-container py-md-6 py-5" id="projects-list">
    <div class="container">
        <p class="mb-4">{{ description }}</p>

        <div class="row g-4">
            {% for project in collections.projects %}
            {% set destination = project.url %}
            {% set imagePath = '/assets/img/projects/' ~ project.data.projectId ~ '/' ~ project.data.projectId ~ '-sm.png' %}
            <div class="col-12">
                <article class="card h-100">
                    <div class="row g-0">
                        <div class="col-md-5 col-lg-4">
                            <img src="{{ imagePath | url }}" class="card-img h-100"
                                alt="{{ project.data.imageAlt or (project.data.title ~ ' screenshot') }}">
                        </div>
                        <div class="col-md-7 col-lg-8">
                            <div class="card-body d-flex flex-column h-100">
                                <h2 class="card-title">{{ project.data.title }}</h2>
                                {%- if project.data.summary %}
                                <p class="card-text">{{ project.data.description }}</p>
                                {%- endif %}
                                <a href="{{ destination }}" class="btn btn-outline-stckr btn-sm me-auto mt-auto">View project</a>
                            </div>
                        </div>
                    </div>
                </article>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

