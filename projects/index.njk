---
layout: base.njk
title: Projects
pageHeading: Projects
cssFile: home
permalink: /projects/
---

<section class="bg-light py-md-6 py-5" id="projects-list">
    <div class="container">
        <p class="mb-4">A list of projects with links to individual pages.</p>

        <div class="row g-4">
            {% for project in collections.projects %}
            {% set destination = project.url %}
            {% set imagePath = project.data.image or ('/assets/img/projects/' ~ project.data.projectId ~ '.png') %}
            <div class="col-12">
                <article class="card h-100">
                    <div class="row g-0">
                        <div class="col-md-5 col-lg-4">
                            <img src="{{ imagePath | url }}" class="card-img rounded-0 h-100"
                                alt="{{ project.data.imageAlt or (project.data.title ~ ' screenshot') }}">
                        </div>
                        <div class="col-md-7 col-lg-8">
                            <div class="card-body d-flex flex-column h-100">
                                <h2 class="card-title">{{ project.data.title }}</h2>
                                {%- if project.data.summary %}
                                <p class="card-text">{{ project.data.summary }}</p>
                                {%- endif %}
                                <a href="{{ destination }}" class="btn btn-outline-stckr btn-sm me-auto mt-auto">View project</a>
                            </div>
                        </div>
                    </div>
                </article>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

