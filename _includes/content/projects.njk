<!-- Projects -->
<section class="projects text-center py-md-5 py-4" id="projects">
    <div class="container text-center">
        <h2 class="mb-5">Web projects</h2>
        <p class="pb-md-5 pb-4">A selection of highlighted personal projects, each chosen to showcase my skills, creativity, and interests in web development.</p>
    </div>
        <div class="container-fluid p-0">
            {% for project in collections.featuredProjects %}
                {% if loop.index0 % 2 == 0 %}
                <div class="row g-0 mb-4">
                {% endif %}
                    {% if loop.index0 % 2 == 1 %}
                        {% set imageOrderClass = 'order-md-1 order-lg-2' %}
                        {% set textOrderClass = 'order-lg-1 order-md-2' %}
                    {% else %}
                        {% set imageOrderClass = 'order-lg-2' %}
                        {% set textOrderClass = 'order-lg-1' %}
                    {% endif %}
                    {% set destination = project.url %}
                    {% set projectId = project.data.projectId %}
                    {% set imagePath = projectId | assetImagePath('png', '', project.data.tags, 'sm') %}
                    {% set imageId = 'project-' ~ loop.index %}
                    <div class="col-lg-6 d-flex align-items-stretch">
                        <div class="row g-0 flex-grow-1 w-100">
                            <div class="col-md-6 {{ textOrderClass }} bg-light align-content-center project-text p-4 p-md-5">
                                <h3>{{ project.data.pageHeading or project.data.title }}</h3>
                                <p class="fs-6 mt-3">{{ project.data.summary }}</p>
                                <p class="fs-6 mb-0 mt-1"><a href="{{ destination }}" class="btn btn-outline-stckr btn-sm">Read more</a></p>
                            </div>
                            <div class="col-md-6 {{ imageOrderClass }} projects-img"
                                style="background-image: url('{{ imagePath | url }}')"
                                aria-describedby="{{ imageId }}"></div>
                            <p class="visually-hidden" id="{{ imageId }}">{{ project.data.imageAlt or project.data.title }}</p>
                        </div>
                    </div>
                {% if loop.index0 % 2 == 1 or loop.last %}
                </div>
                {% endif %}
            {% endfor %}
        </div>
        <div class="mt-5">
            <a class="btn btn-stckr" href="{{ '/projects' | url}}">View all projects</a>
        </div>
    </div>
</section>