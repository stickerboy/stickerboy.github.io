{% set socialList = social | selectattr(socialAttr, "equalto", true) | list %}
<section class="features-icons bg-light text-center py-md-5 py-4" id="social">
    <div class="container">
        <div class="grid">
            {%- for item in socialList %}
            <div class="features-icon-item p-3 p-3 rounded g-col-6 g-col-sm-4 g-col-lg-2 position-relative">
                <a href="{{ item.url }}" class="features-icons-icon d-flex justify-content-center align-items-center stretched-link" 
                    title="{{ item.title | default('Link to Kenny\'s profile on ' ~ item.platform) }} - @{{ item.handle }}">
                    {%- if item.svg %}
                    {%- include "svg/" ~ item.svg ~ ".njk" %}
                    {%- else %}
                    <i class="{{ item.icon }} m-auto text-body"></i>
                    {%- endif %}
                </a>
                <p class="mb-0">@{{ item.handle }}</p>
            </div>
            {%- endfor %}
        </div>
    </div>
</section>